generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        Int             @id @default(autoincrement())
  name      String
  email     String          @unique
  password  String
  phone     String?         @unique
  createdAt DateTime        @default(now())
  entrepreneurProfile EntrepreneurProfile?

  serviceRequests ServiceRequest[]
  reviews Review[]

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model EntrepreneurProfile {
  id        Int      @id @default(autoincrement())

  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio       String?
  location  String
  avatarUrl String?

  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  experiences Experience[]
  categories  Category[]
  services    Service[]

  @@index([location])
}

model Experience {
  id          Int      @id @default(autoincrement())

  profileId   Int
  profile     EntrepreneurProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // ✅ NEW: link each experience to a category (skill)
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])

  // ✅ UPDATED: optional sector
  sector      String?
  years       Int
  isCurrent   Boolean
  description String?

  createdAt   DateTime @default(now())

  @@index([profileId])
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  icon        String?

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entrepreneurs EntrepreneurProfile[]

  // ✅ NEW: reverse relation
  experiences   Experience[]
}

model Service {
  id          Int      @id @default(autoincrement())

  title       String
  description String?
  price       Float

  profileId   Int
  profile     EntrepreneurProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  requests ServiceRequest[]
  reviews Review[]

  createdAt   DateTime @default(now())
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ServiceRequest {
  id        Int      @id @default(autoincrement())

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  message   String?

  status    RequestStatus @default(PENDING)

  sellerMessage String?
  seenByUser    Boolean @default(false)

  createdAt DateTime @default(now())
  review Review?

  @@index([serviceId])
}

model Review {
  id        Int      @id @default(autoincrement())

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  requestId Int      @unique
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  rating    Int
  comment   String?

  createdAt DateTime @default(now())
}